# Together AI API Key (Required)
# Get your API key from https://www.together.ai/
TOGETHER_API_KEY=your_together_api_key_here

# OpenRouter API Key (Optional)
# Used for judge models with the openrouter/ prefix, e.g. openrouter/<model-id>
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic API Key (Optional)
# Used for judge models with the anthropic/ prefix
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Ollama base URL (Optional)
# Used for judge models with the ollama/ prefix, defaults to http://127.0.0.1:11434
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Neon Database URL (Required)
# Get this from Neon Dashboard > Connection Details
# Format: postgresql://user:password@host/database?sslmode=require
DATABASE_URL=your_neon_database_url_here

# Vercel Blob Storage Token (Required for web interface)
# Used for storing uploaded PDFs
# Get this from Vercel Dashboard > Storage > Blob > Connect
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here
