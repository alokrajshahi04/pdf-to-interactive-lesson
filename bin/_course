#compdef course

# Zsh completion for course CLI
# Install: ln -sf $PWD/bin/_course /usr/local/share/zsh/site-functions/_course

_course() {
  local curcontext="$curcontext" state line
  typeset -A opt_args

  local commands=(
    'generate:Generate a complete course from PDF/markdown'
    'gen:Generate a complete course (alias)'
    'modules:Generate only course structure (no lessons)'
    'mod:Generate only modules (alias)'
    'help:Show help message'
    'version:Show version number'
  )

  _arguments -C \
    '1: :->command' \
    '2: :->file' \
    '*: :->options'

  case $state in
    command)
      _describe -t commands 'course commands' commands
      ;;
    file)
      case $words[2] in
        generate|gen|modules|mod)
          _files -g "*.{pdf,md,txt}"
          ;;
      esac
      ;;
    options)
      local options=(
        '--output[Save output to specific path]:file:_files'
        '--save-text[Save extracted text to file]:file:_files'
        '--save-text-auto[Save text next to PDF as .md]'
        '--no-validate[Skip all validation]'
        '--no-validate-structure[Skip structure validation]'
        '--no-validate-content[Skip content validation]'
        '--no-retry[Disable auto-fix of failed lessons]'
        '--max-retries[Max retry attempts]:number:'
        '--runs[Run generation n times]:number:'
      )
      _arguments $options
      ;;
  esac
}

_course "$@"

