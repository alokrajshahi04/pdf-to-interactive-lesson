{
  "name": "pdf-to-interactive-lesson",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.5.0",
  "scripts": {
    "setup": "pnpm install && cd api && uv venv && uv pip install -e . && cd .. && echo '\n✅ Setup complete! Copy .env.example to .env.local and add your API keys.'",
    "dev": "concurrently \"pnpm:dev:next\" \"pnpm:dev:api\" --names \"next,api\" --prefix-colors \"cyan,magenta\"",
    "dev:next": "next dev",
    "dev:api": "cd api && source .venv/bin/activate && python app.py",
    "kill": "pkill -f 'python app.py' && pkill -f 'next dev' && echo '✅ Killed all dev servers' || echo '✅ No dev servers running'",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "pdf-to-image": "node scripts/pdf-to-image.ts",
    "generate-course": "tsx lib/cli.ts",
    "test:grade": "tsx scripts/test-grade-short-answer.ts"
  },
  "pnpm": {
    "overrides": {
      "canvas": "npm:@napi-rs/canvas@^0.1.81"
    }
  },
  "resolutions": {
    "canvas": "npm:@napi-rs/canvas@^0.1.81"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^2.0.38",
    "@ai-sdk/openai": "^2.0.56",
    "@ai-sdk/togetherai": "^1.0.24",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@napi-rs/canvas": "^0.1.81",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/dagre": "^0.7.53",
    "@upstash/redis": "^1.35.6",
    "@vercel/blob": "^2.0.0",
    "@xyflow/react": "^12.9.3",
    "ai": "^5.0.81",
    "axios": "^1.13.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dagre": "^0.8.5",
    "fast-xml-parser": "^5.3.0",
    "inngest": "^3.44.3",
    "lucide-react": "^0.552.0",
    "next": "16.0.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "4.8.69",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "sharp": "0.33.5",
    "tailwind-merge": "^3.3.1",
    "together-ai": "^0.28.0",
    "vaul": "^1.1.2",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}